{
    "name": "silvershop/coloredvariations",
    "description": "Add color support to variations for SilverShop.",
    "type": "silverstripe-vendormodule",
    "license": "BSD-2-Clause",
    "keywords": [
        "silverstripe",
        "ecommerce",
        "shop",
        "comparison",
        "color"
    ],
    "require": {
        "silvershop/core": "^6"
    },
    "authors": [
        {
            "name": "SilverShop Contributors",
            "homepage": "https://github.com/silvershop/silvershop-coloredvariations/graphs/contributors"
        }
    ],
    "require-dev": {
        "cambis/silverstan": "^2.1",
        "silverstripe/recipe-testing": "^4",
        "squizlabs/php_codesniffer": "^3.0"
    },
    "prefer-stable": true,
    "minimum-stability": "dev",
    "extra": {
        "branch-alias": {
            "dev-main": "6.x-dev"
        },
        "project-files-installed": [
            "behat.yml",
            "phpunit.xml.dist"
        ]
    },
    "autoload": {
        "psr-4": {
            "SilverShop\\ColoredVariations\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SilverShop\\ColoredVariations\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "silverstripe/recipe-plugin": true,
            "silverstripe/vendor-plugin": true
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "stan": "vendor/bin/phpstan analyse --configuration=phpstan.neon"
    }
}
